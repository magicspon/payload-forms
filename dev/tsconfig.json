{
  "extends": "../tsconfig.json",
  "exclude": [
    "**/*.stories.tsx",
    "**/*.stories.ts"
  ],
  "include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.ts",
    "**/*.tsx",
    "../src/**/*.ts",
    "../src/**/*.tsx",
    "next.config.mjs",
    ".next/types/**/*.ts"
  ],
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@payload-config": [
        "./payload.config.ts"
      ],
      "@spon/payload-forms": [
        "../src/index.ts"
      ],
      "@spon/payload-forms/client": [
        "../src/exports/client.ts"
      ],
      "@spon/payload-forms/rsc": [
        "../src/exports/rsc.ts"
      ],
      "@spon/payload-forms/form": [
        "../src/exports/form.ts"
      ],
      "@forms/*": [
        "./form/*"
      ],
      "@ui/primitives/*": [
        "./ui/*"
      ],
      "@ui/utils/cn": [
        "./ui/utils/cn"
      ],
      "@/*": [
        "../src/*"
      ]
    },
    "noEmit": true,
    "emitDeclarationOnly": false,
  }
}
