{
  "name": "@spon/payload-forms",
  "version": "0.3.0",
  "description": "Payload CMS plugin — visual form builder with drag-drop editor, submissions, notifications, and optional multitenancy",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "import": "./src/exports/client.ts",
      "types": "./src/exports/client.ts",
      "default": "./src/exports/client.ts"
    },
    "./rsc": {
      "import": "./src/exports/rsc.ts",
      "types": "./src/exports/rsc.ts",
      "default": "./src/exports/rsc.ts"
    },
    "./form": {
      "import": "./src/exports/form.ts",
      "types": "./src/exports/form.ts",
      "default": "./src/exports/form.ts"
    },
    "./builder": {
      "import": "./src/exports/builder.ts",
      "types": "./src/exports/builder.ts",
      "default": "./src/exports/builder.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "repository": {
    "url": "https://github.com/magicspon/payload-forms"
  },
  "author": {
    "name": "Dave Stockley",
    "email": "magicspon@gmail.com"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "dev": "next dev dev --turbo",
    "dev:generate-importmap": "pnpm dev:payload generate:importmap",
    "dev:generate-types": "pnpm dev:payload generate:types",
    "dev:payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts payload",
    "generate:importmap": "pnpm dev:generate-importmap",
    "generate:types": "pnpm dev:generate-types",
    "format": "prettier --write \"**/*.{ts,tsx,md,css}\"",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "release": "changeset publish",
    "typecheck": "tsc --noEmit",
    "dev:build": "next build dev",
    "dev:start": "next start dev -p 3001",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:e2e": "pnpm dev:build && playwright test",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "test:unit": "vitest"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@payloadcms/db-sqlite": "3.84.1",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/store": "^0.11.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "22.19.9",
    "@types/papaparse": "^5.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.0.18",
    "class-variance-authority": "^0.7.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.23.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "fallow": "^2.91.0",
    "graphql": "^16.8.1",
    "next": "16.2.6",
    "payload": "3.84.1",
    "prettier": "^3.4.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rimraf": "3.0.2",
    "sharp": "0.34.2",
    "tailwindcss": "^4.3.0",
    "tsdown": "^0.22.0",
    "typescript": "5.7.3",
    "unrun": "^0.3.1",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "payload": "^3.84.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./client": {
        "import": "./dist/exports/client.js",
        "types": "./dist/exports/client.d.ts",
        "default": "./dist/exports/client.js"
      },
      "./rsc": {
        "import": "./dist/exports/rsc.js",
        "types": "./dist/exports/rsc.d.ts",
        "default": "./dist/exports/rsc.js"
      },
      "./form": {
        "import": "./dist/exports/form.js",
        "types": "./dist/exports/form.d.ts",
        "default": "./dist/exports/form.js"
      },
      "./builder": {
        "import": "./dist/exports/builder.js",
        "types": "./dist/exports/builder.d.ts",
        "default": "./dist/exports/builder.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "registry": "https://registry.npmjs.org/",
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "1.8.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "1.1.0",
    "clsx": "^2.1.1",
    "papaparse": "^5.5.3",
    "zod": "^4.4.3"
  }
}
